# === LLM Provider Keys (at least one required, or set MOCK_MODE=1) ===
ANTHROPIC_API_KEY=your_anthropic_key_here
OPENAI_API_KEY=your_openai_key_here
GITHUB_TOKEN=your_github_token_here

# === Custom OpenAI-compatible endpoint (Ollama, vLLM, etc.) ===
# CUSTOM_LLM_BASE_URL=http://localhost:11434/v1
# CUSTOM_LLM_API_KEY=optional_key

# === Per-Agent Model Configuration (format: provider/model-name) ===
# SENTINEL_MODEL=anthropic/claude-sonnet-4-5-20250514
# WATCHDOG_MODEL=openai/gpt-4o
# GUARDIAN_MODEL=github/gpt-4o
# SYNTHESIZER_MODEL=anthropic/claude-sonnet-4-5-20250514
# AEGIS_DEFAULT_MODEL=anthropic/claude-sonnet-4-5-20250514

# === Mock Mode (set to 1 to use pre-computed responses, no API key needed) ===
# Enabled by default so `docker compose up` works immediately.
# Remove this line after configuring real API keys above.
MOCK_MODE=1

# === Server Configuration ===
PORT=3001
CORS_ORIGIN=http://localhost:3000
