# === LLM Provider Keys (at least one required, or set MOCK_MODE=1) ===
ANTHROPIC_API_KEY=your_anthropic_key_here
OPENAI_API_KEY=your_openai_key_here
GITHUB_TOKEN=your_github_token_here

# === GitHub Copilot (premium models: GPT-5.4, Claude Opus/Sonnet via api.githubcopilot.com) ===
# Set this to a GitHub OAuth token (ghu_* prefix) for Copilot Enterprise access.
# Alternatively, place the token in ~/.local/share/copilot-api/github_token
# or set GITHUB_TOKEN to a ghu_* token.
# COPILOT_GITHUB_TOKEN=ghu_your_copilot_token_here

# === Custom OpenAI-compatible endpoint (Ollama, vLLM, etc.) ===
# CUSTOM_LLM_BASE_URL=http://localhost:11434/v1
# CUSTOM_LLM_API_KEY=optional_key

# === Per-Agent Model Configuration (format: provider/model-name) ===
# SENTINEL_MODEL=copilot/claude-sonnet-4.5
# WATCHDOG_MODEL=copilot/gpt-5.4
# GUARDIAN_MODEL=copilot/claude-opus-4.6
# SYNTHESIZER_MODEL=copilot/gpt-5.4
# AEGIS_DEFAULT_MODEL=copilot/claude-sonnet-4.5

# === Mock Mode (set to 1 to use pre-computed responses, no API key needed) ===
# Enabled by default so `docker compose up` works immediately.
# Remove this line after configuring real API keys above.
MOCK_MODE=1

# === Server Configuration ===
PORT=3001
CORS_ORIGIN=http://localhost:3000
