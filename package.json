{
  "name": "aegis",
  "private": true,
  "scripts": {
    "dev": "run-p dev:api dev:web",
    "dev:api": "pnpm --filter @aegis/api dev",
    "dev:web": "pnpm --filter @aegis/web dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "docker:up": "docker compose up --build",
    "docker:down": "docker compose down"
  },
  "engines": {
    "node": ">=20"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3"
    ]
  },
  "devDependencies": {
    "npm-run-all2": "^8.0.4"
  }
}
